# Webpack configuration to fix Watchpack Error on Windows
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true
GENERATE_SOURCEMAP=false

# Ignore system directories
WATCHPACK_IGNORED_PATHS=D:\System Volume Information
PORT=3000
HOST=localhost

# Firebase Configuration (set these in your local .env, do not commit secrets)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Facebook Configuration (set locally)
REACT_APP_FACEBOOK_APP_ID=
REACT_APP_FACEBOOK_APP_SECRET=

# AdMob Configuration (set locally)
REACT_APP_ADMOB_BANNER_ID=
